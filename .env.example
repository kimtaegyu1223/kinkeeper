# Telegram
TELEGRAM_BOT_TOKEN=changeme_from_botfather
# 예: -1001234567890 (음수). 값 뒤 인라인 주석은 systemd가 값의 일부로 넘겨 파싱 실패하므로 붙이지 말 것.
GROUP_CHAT_ID=changeme_group_chat_id
# 운영 경보(healthz/발송실패) 수신처 — 관리자 개인 텔레그램 user id. 비우면 GROUP_CHAT_ID로 폴백.
# 관리자가 봇에게 /start를 보낸 적이 있어야 DM 수신 가능.
ADMIN_CHAT_ID=changeme_admin_user_id

# Database (docker-compose postgres)
DATABASE_URL=postgresql+psycopg://family:changeme@localhost:5432/family_notifier
POSTGRES_USER=family
POSTGRES_PASSWORD=changeme
POSTGRES_DB=family_notifier

# Admin web (HTTP Basic)
ADMIN_USER=admin
# bcrypt hash — generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpw', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=changeme_bcrypt_hash

# App
TZ=Asia/Seoul
LOG_LEVEL=INFO
SCHEDULE_HORIZON_DAYS=90
