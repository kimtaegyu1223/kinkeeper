# Telegram
TELEGRAM_BOT_TOKEN=changeme_from_botfather
GROUP_CHAT_ID=changeme_group_chat_id  # 예: -1001234567890 (음수)

# Database (docker-compose postgres)
DATABASE_URL=postgresql+psycopg://family:changeme@localhost:5432/family_notifier
POSTGRES_USER=family
POSTGRES_PASSWORD=changeme
